---
import Navbar from '../../components/Navbar.jsx'
import '../../styles/global.css'
import '../../styles/events.css'
import '../../styles/question.css'
import { Image } from 'astro:assets';

import FblaLogo from '../../images/fbla-logo.png'
import { IoClose } from "react-icons/io5";
---

<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JCHS FBLA</title>
</head>

<body>
    <div class="header-container">
        <Navbar type="flat" client:load />
    </div>
    <div>
        <div class="event-title">
            REGION LEADERSHIP CONFERENCE (RLC)
        </div>
        <div class="divider-row">
            <hr class="title-divider"/>
        </div>
    </div>

    <div class="find-event-container">
        <div class="find-event-container-title">Having Trouble Deciding Which Competitive Event To Do?​</div>
        <a href="https://storage.googleapis.com/articulate-courses/BAA%20Contributor/Choose%20Your%20Event%20(FBLA)%20-%20Storyline%20output/story.html" class="find-event-container-link" target="_blank">Click Here for Help Choosing Your Competitive Event</a>
    </div>

    <div class="info-container">
        <h1 class="info-title">About RLC</h1>
        <p class="info-description">
            FBLA members can compete at a variety of competitive events at the Region Leadership Conference each year to qualify for the State Leadership Conference (SLC). For more information about the competitive events offered at the RLC, see the list of competitive events below.
        </p>
    </div>

    <div class="info-container">
        <h1 class="info-title">Pricing & Dates</h1>
        <div class="info-list">
            <div class="info-list-item">
                January, 2024 (After School) (Exact Date TBD)
            </div>
            <div class="info-list-item">
                Attending - TBD
            </div>
            <div class="info-list-item">
                Not Attending - TBD
            </div>
        </div>
    </div>

    <div class="info-container">
        <h1 class="info-title">Location</h1>
        <div class="info-list">
            <div class="info-list-item">
                Alpharetta High School
            </div>
            <div class="info-list-item">
                3595 Webb Bridge Rd, Alpharetta, GA 30005
            </div>
        </div>
        
        <button id="question-button">
            <Image src={FblaLogo} width="100" height="100" alt="FBLA Logo" />
        </button>

        <script>
            const qButton = document.getElementById('question-button');
            const qClose = document.getElementById("question-close");
            qButton?.addEventListener("click", () => {
                const questionContainer = document.getElementsByClassName("fixed-question")[0];
                questionContainer.classList.toggle("hidden");
            })
            qClose?.addEventListener("click", () => {
                const questionContainer = document.getElementsByClassName("fixed-question")[0];
                questionContainer.classList.toggle("hidden");
            })
        </script>

        <div class="fixed-question hidden">
            <div id="question-close">
                <IoClose />
            </div>
            <div class="q-title">
                You've found a logo, answer this question!
            </div>
            <div class="q-question">
                Around how many events does FBLA offer?
            </div>
        </div>
    </div>
</body>
</html>
