---
import Navbar from '../../components/Navbar.jsx'
import '../../styles/global.css'
import '../../styles/events.css'
import '../../styles/question.css'
import { Image } from 'astro:assets';
import RemindLogo from '../../images/remind-logo-social.png'
import InstagramLogo from '../../images/instagram-logo-social.png'
import GmailLogo from '../../images/gmail-logo-social.png'

import FblaLogo from '../../images/fbla-logo.png'
import { IoClose } from "react-icons/io5";
---


<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JCHS FBLA</title>
</head>
<body>
    <div class="header-container">
        <Navbar type="flat" client:load />
    </div>
    <div>
        <div class="event-title">
            SOCIALS & CONTACTS
        </div>
        <div class="divider-row">
            <hr class="title-divider"/>
        </div>
    </div>

    <div class="social-container" style="margin-top: 40px">
        <Image src={RemindLogo} alt="Remind Logo" class="social-logo"/>
        <h1 class="team-title">Remind</h1>
        <div class="info-list">
            <div class="team-list-item">
                Freshman: @jcfbla28
            </div>
            <div class="team-list-item">
                Sophomores: @jcfbla27
            </div>
            <div class="team-list-item">
                Juniors: @jcfbla26
            </div>
            <div class="team-list-item">
                Seniors: @jcfbla25
            </div>
        </div>
    </div>

    <div class="social-container" style="margin-top: -10px">
        <Image src={InstagramLogo} alt="Remind Logo" class="social-logo"/>
        <h1 class="team-title">Instagram</h1>
        <div class="info-list">
            <div class="team-list-item">
                @jchsfbla
            </div>
        </div>
    </div>

    <div class="social-container" style="margin-top: -10px; position: relative;">
        <Image src={GmailLogo} alt="Remind Logo" class="social-logo"/>
        <h1 class="team-title">Gmail</h1>
        <div class="info-list">
            <div class="team-list-item">
                jchsfbla@gmail.com
            </div>
        </div>

        <button id="question-button" style="position:absolute; top: 0; right: 0;">
            <Image src={FblaLogo} width="100" height="100" alt="FBLA Logo" />
        </button>
    
        <script>
            const qButton = document.getElementById('question-button');
            const qClose = document.getElementById("question-close");
            qButton?.addEventListener("click", () => {
                const questionContainer = document.getElementsByClassName("fixed-question")[0];
                questionContainer.classList.toggle("hidden");
            })
            qClose?.addEventListener("click", () => {
                const questionContainer = document.getElementsByClassName("fixed-question")[0];
                questionContainer.classList.toggle("hidden");
            })
        </script>
    
        <div class="fixed-question hidden">
            <div id="question-close">
                <IoClose />
            </div>
            <div class="q-title">
                You've found a logo, answer this question!
            </div>
            <div class="q-question">
                What is our instagram handle?
            </div>
        </div>
    </div>
</body>
</html>